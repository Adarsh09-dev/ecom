<!DOCTYPE html>
<html>
<head>
  <title>Cart</title>
  <link rel="stylesheet" href="/cart-style/cart-page.css">
</head>
<body>

<div class="cart-container">

  <!-- LEFT: CART ITEMS -->
  <div class="cart-left">

    <h2 class="cart-title">Shopping Cart</h2>

    <% if (cartItems.length === 0) { %>
      <p class="empty">Cart is empty</p>
    <% } else { %>

      <% cartItems.forEach(function(item){ %>

        <div class="cart-card">

          
          <div class="details">
            <h3><%= item.productId?.name || 'No Name' %></h3>
            <p class="price">₹<%= item.productId?.price || 0 %></p>
            <!-- Quantity -->
            <div class="qty-box">

              <form action="/cart/update" method="POST">
                <input type="hidden" name="cartItemId" value="<%= item._id %>">
                <input type="hidden" name="action" value="decrease">
                <button class="qty-btn">−</button>
              </form>

              <span class="qty"><%= item.quantity %></span>

              <form action="/cart/update" method="POST">
                <input type="hidden" name="cartItemId" value="<%= item._id %>">
                <input type="hidden" name="action" value="increase">
                <button class="qty-btn">+</button>
              </form>

            </div>

            <img src="<%= item.productId.image %>" alt="product" class="product-img">
         




          </div>

        </div>

      <% }) %>

    <% } %>

  </div>

  <!-- RIGHT: SUMMARY -->
  <div class="cart-right">

    <h3>Order Summary</h3>

    <div class="summary-row">
      <span>Subtotal</span>
      <span>₹500</span>
    </div>

    <div class="summary-row">
      <span>Shipping</span>
      <span class="free">Free</span>
    </div>

    <hr>

    <div class="summary-row total">
      <span>Total</span>
      <span>₹500</span>
    </div>

    <button class="checkout-btn">Proceed to Checkout</button>

  </div>

</div>

</body>
</html>