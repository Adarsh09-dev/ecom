<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Category List</title>
  <link rel="stylesheet" href="/category-style/category-H.css">
</head>

<body>

<div class="dashboard">
  
  <!-- SIDEBAR -->
  <aside class="sidebar">
    <h2 class="logo">swapZon</h2>
  
 
    <div class="">   <ul class="menu">
      <li>Dashboard</li>
      <li class="active">Categories</li>
      <li> <a href="/sub-category"  > Sub Category </a>  </li>
      <li> <a href="/product"> Products </a>  </li>
  
    </ul>
  </div>


      <div class="lg-btn"> <form action="/admin/logout" method="post">
           <button type="submit" class="logout">Log Out</button>
                 </form>
      </div>


  </aside>

  <!-- MAIN CONTENT -->
  <main class="main">

<div class="topbar">
  <input type="text" placeholder="Search Category">

  <a href="/category/add-category">
    <button class="add-btn">Add Category +</button>
  </a>

</div>

    <div class="card">
      <h3>All Categories</h3>

<table>
  <thead>
    <tr>
      <th>Image</th>
      <th>Name</th>
      <th>Created Date</th>
      <th>Updated Date</th>
      <th>Action</th>
    </tr>
  </thead>

  <tbody>

  <% if (categories && categories.length > 0) { %>

    <% categories.forEach(category => { %>

<tr>

<td>
  <img src="<%= category.image %>" width="50" height="50">
</td>

<td>
  <%= category.name %>
</td>

<td>
  <%= category.createdAt.toDateString() %>
</td>

<td>
  <%= category.updatedAt.toDateString() %>
</td>

<td class="actions">

  <!-- EDIT -->
  <a href="/category/edit/<%= category._id %>" class="btn edit-btn">
    Edit
  </a>

  <!-- DELETE -->
  <form action="/category/<%= category._id %>?_method=DELETE" method="POST">
    <button type="submit" class="btn delete-btn">Delete</button>
  </form>

</td>

</tr>

    <% }) %>

  <% } else { %>

<tr>
<td colspan="5" style="text-align:center;">
No Categories Found
</td>
</tr>

  <% } %>

  </tbody>
</table>

      <div class="pagination">

  <!-- Previous Button -->
  <a href="/admin?page=<%= currentPage - 1 %>"
     class="page-btn <%= currentPage === 1 ? 'disabled' : '' %>">
     Previous
  </a>

  <!-- Page Numbers -->
  <% for (let i = 1; i <= totalPages; i++) { %>
    <a href="/admin?page=<%= i %>" 
       class="page-btn <%= currentPage === i ? 'active' : '' %>">
       <%= i %>
    </a>
  <% } %>

  <!-- Next Button -->
  <a href="/admin?page=<%= currentPage + 1 %>"
     class="page-btn <%= currentPage === totalPages ? 'disabled' : '' %>">
     Next
  </a>

</div>


    </div>

  </main>

</div>

</body>
</html>