<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Product List</title>
  <link rel="stylesheet" href="/category-style/category-H.css">
</head>

<body>

<div class="dashboard">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <h2 class="logo">Esale</h2>

    <ul class="menu">
      <li>Dashboard</li>
      <li><a href="/category">Categories</a></li>
      <li><a href="/sub-category">Sub Category</a></li>
      <li class="active"><a href="/product">Products</a></li>
      <li>Customers</li>
    </ul>

  </aside>

  <!-- MAIN CONTENT -->
  <main class="main">

<div class="topbar">
  <input type="text" placeholder="Search Product">

  <a href="/product/add">
    <button class="add-btn">Add Product +</button>
  </a>

</div>

<% if (typeof success !== 'undefined' && success) { %>
  <div style="color: green; margin: 10px; padding: 10px; border: 1px solid green; background: #e8f5e8;">
    <%= success %>
  </div>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
  <div style="color: red; margin: 10px; padding: 10px; border: 1px solid red; background: #ffeaea;">
    <%= error %>
  </div>
<% } %>

    <div class="card">
      <h3>All Products</h3>

      <table>
        <thead>
          <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Category</th>
            <th>Sub Category</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Created Date</th>
          </tr>
        </thead>

        <tbody>

          <% if (products && products.length > 0) { %>

            <% products.forEach(product => { %>

<tr>

<td>
  <img src="<%= product.image %>" width="50" height="50" alt="Product Image">
</td>

<td>
  <%= product.name %>
</td>

<td>
  <%= product.category ? product.category.name : 'N/A' %>
</td>

<td>
  <%= product.subCategory ? product.subCategory.name : 'N/A' %>
</td>

<td>
  <%= product.price %>
</td>

<td>
  <%= product.stock %>
</td>

<td>
  <%= product.createdAt.toDateString() %>
</td>

<td class="actions">

  <!-- EDIT -->
  <!-- <a href="/product/edit/<%= product._id %>" class="btn edit-btn">
    Edit
  </a> -->

  <!-- DELETE -->
  <!-- <form action="/product/<%= product._id %>?_method=DELETE" method="POST">
    <button type="submit" class="btn delete-btn">
      Delete
    </button>
  </form> -->

</td>

</tr>

            <% }) %>

          <% } else { %>

<tr>
<td colspan="7">No products found</td>
</tr>

          <% } %>

        </tbody>
      </table>

    </div>

  </main>

</div>

</body>
</html>